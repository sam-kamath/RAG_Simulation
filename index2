<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>RAG Simulator</title>

<style>

body{
margin:0;
font-family:Inter,system-ui;
background:linear-gradient(135deg,#0f172a,#020617);
color:white;
}

.container{
max-width:1200px;
margin:auto;
padding:40px;
}

h1{
text-align:center;
font-weight:600;
margin-bottom:30px;
}

.pipeline{
display:flex;
gap:10px;
justify-content:center;
flex-wrap:wrap;
margin-bottom:40px;
}

.stage{
background:#1e293b;
padding:10px 16px;
border-radius:8px;
font-size:13px;
opacity:.7;
}

.card{
background:#1e293b;
border-radius:14px;
padding:20px;
margin-bottom:20px;
box-shadow:0 10px 30px rgba(0,0,0,.4);
}

.grid{
display:grid;
grid-template-columns:1fr 1fr;
gap:20px;
}

textarea,input{
width:100%;
padding:12px;
margin-top:10px;
border-radius:8px;
border:none;
background:#0f172a;
color:white;
}

button{
margin-top:12px;
padding:10px 18px;
border-radius:8px;
border:none;
background:#6366f1;
color:white;
cursor:pointer;
}

button:hover{
background:#4f46e5;
}

.chunk{
background:#334155;
padding:12px;
border-radius:10px;
margin-top:10px;
font-size:14px;
}

.vector{
font-family:monospace;
font-size:12px;
color:#93c5fd;
margin-top:5px;
}

.retrieved{
background:#065f46;
}

.result{
background:#020617;
border-radius:10px;
padding:15px;
margin-top:10px;
font-size:14px;
white-space:pre-wrap;
}

</style>
</head>

<body>

<div class="container">

<h1>Retrieval Augmented Generation Simulator</h1>

<div class="pipeline">

<div class="stage">Dataset</div>
<div class="stage">Chunking</div>
<div class="stage">Embeddings</div>
<div class="stage">Vector DB</div>
<div class="stage">Query Embedding</div>
<div class="stage">Similarity Search</div>
<div class="stage">Top-K Retrieval</div>
<div class="stage">Prompt Augmentation</div>
<div class="stage">LLM Answer</div>

</div>

<div class="card">

<h3>1️⃣ Provide Dataset</h3>

<textarea id="dataset" rows="6">
Blinkit delivers groceries in minutes across Indian cities.
Swiggy and Zomato dominate food delivery in India.
Protein rich food helps muscle growth and recovery.
RAG stands for Retrieval Augmented Generation.
Vector databases store embeddings for semantic search.
</textarea>

<button onclick="ingest()">Ingest Dataset</button>

<div id="chunks"></div>

</div>

<div class="card">

<h3>2️⃣ Ask a Question</h3>

<input id="query" placeholder="Ask something about the dataset">

<button onclick="runRAG()">Run RAG</button>

</div>

<div class="grid">

<div class="card">

<h3>Vector Database</h3>

<div id="vectordb"></div>

</div>

<div class="card">

<h3>Retrieved Context (Top-K)</h3>

<div id="retrieved"></div>

</div>

</div>

<div class="card">

<h3>Prompt Sent to LLM</h3>

<div id="prompt" class="result"></div>

</div>

<div class="card">

<h3>Generated Answer</h3>

<div id="answer" class="result"></div>

</div>

</div>

<script>

let vectors=[]

function embed(text){

let vec=[]

for(let i=0;i<6;i++){

vec.push(Math.random())

}

return vec

}

function ingest(){

vectors=[]

let data=document.getElementById("dataset").value
let lines=data.split("\n").filter(x=>x.trim()!="")

let chunkHTML=""

lines.forEach((line,i)=>{

let emb=embed(line)

vectors.push({text:line,vector:emb})

chunkHTML+=`
<div class="chunk">
<b>Chunk ${i+1}</b><br>
${line}
<div class="vector">Embedding: [${emb.map(v=>v.toFixed(2)).join(", ")}]</div>
</div>
`

})

document.getElementById("chunks").innerHTML=chunkHTML

renderDB()

}

function renderDB(){

let html=""

vectors.forEach(v=>{

html+=`
<div class="chunk">
${v.text}
<div class="vector">[${v.vector.map(n=>n.toFixed(2)).join(", ")}]</div>
</div>
`

})

document.getElementById("vectordb").innerHTML=html

}

function similarity(a,b){

let score=0

for(let i=0;i<a.length;i++){

score+=1-Math.abs(a[i]-b[i])

}

return score

}

function runRAG(){

let q=document.getElementById("query").value

let qvec=embed(q)

let scored=vectors.map(v=>{

return{

text:v.text,
score:similarity(qvec,v.vector)

}

})

scored.sort((a,b)=>b.score-a.score)

let top=scored.slice(0,3)

let retrievedHTML=""

top.forEach(r=>{

retrievedHTML+=`
<div class="chunk retrieved">
${r.text}
</div>
`

})

document.getElementById("retrieved").innerHTML=retrievedHTML

let context=top.map(x=>x.text).join("\n")

let prompt=`Use the following context to answer the question.

Context:
${context}

Question:
${q}`

document.getElementById("prompt").innerText=prompt

let answer="Based on retrieved context:\n\n"

answer+=context.split(".")[0]+"."

document.getElementById("answer").innerText=answer

}

</script>

</body>
</html>
